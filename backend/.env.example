DATABASE_URL=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
SECURE_SSL_REDIRECT=False

# Cloudinary API Credentials
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=

# Other Configuration Variables
# Add other environment variables here as needed

# Google OAuth2 Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Field-level encryption key (Fernet)
FIELD_ENCRYPTION_KEY=

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=
MPESA_PUBLIC_CERT_PATH=
MPESA_ENVIRONMENT=sandbox
MPESA_B2C_RESULT_URL=
MPESA_B2C_TIMEOUT_URL=
MPESA_DISBURSEMENT_BLACKOUT_START=01:00
MPESA_DISBURSEMENT_BLACKOUT_END=04:00
# Comma-separated CIDR ranges allowed to call M-Pesa callbacks; empty = allow all
MPESA_CALLBACK_IP_WHITELIST=
# Optional HMAC secret for additional callback verification
MPESA_CALLBACK_HMAC_SECRET=

# Google AI (Gemini)
GOOGLE_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
GOOGLE_AI_TEMPERATURE=0.7
GOOGLE_AI_MAX_TOKENS=4096
GOOGLE_AI_TIMEOUT=30

# Africa's Talking SMS
AT_API_KEY=
AT_USERNAME=
AT_API_URL=https://api.sandbox.africastalking.com/version1/messaging
NOTIFICATIONS_DRY_RUN=True

# Legal Document Rate Limit
LEGAL_RATE_LIMIT=20/min

# Redis / Celery
REDIS_URL=
CELERY_TASK_ALWAYS_EAGER=False

# Database connection pool (optional — omit to use persistent connections only)
DB_POOL_MIN=
DB_POOL_MAX=

